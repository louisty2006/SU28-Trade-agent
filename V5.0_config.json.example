{
  "_comment": "REISHI v5.0 - Orchestrator 对接配置示例（本檔為範例，檔名 V5.0_config.json.example）",
  "_usage": "使用時請複製為 config.json，或由 Orchestrator 寫入 config.json；回測時 BacktestEngine 會讀取 config.json",
  
  "stage1_weights": {
    "rsi": 0.20,
    "macd": 0.15,
    "kd": 0.12,
    "bollinger": 0.10,
    "volume": 0.08,
    "price_momentum": 0.15,
    "from_high": 0.10,
    "from_low": 0.10
  },
  
  "stage2_weights": {
    "stage1_score": 0.30,
    "financial_health": 0.25,
    "valuation": 0.20,
    "growth": 0.15,
    "news_sentiment": 0.10
  },
  
  "backtest_initial_cash": 40000.0,
  "backtest_pct_per_new_entry": 0.20,
  "backtest_add_pct": 0.10,
  "backtest_reduce_pct": 0.50,
  
  "_output": {
    "summary": "reports/backtest_range/{date_range}/backtest_summary.csv",
    "trades": "reports/backtest_range/{date_range}/backtest_trades.csv"
  }
}
