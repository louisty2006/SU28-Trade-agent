# REISHI 霊視 v5.0 MVP - 配置文件

# 应用信息
app:
  name: "REISHI Stock Scanner"
  version: "5.0.0"
  mode: "MVP"

# 数据源配置
data_sources:
  price:
    primary: "yahoo"
    secondary: "finnhub"
    fallback: "iex"
  
  news:
    primary: "finnhub"
    secondary: "yahoo_rss"
    fallback: "google_news"
  
  financials:
    primary: "yahoo"
    secondary: "finnhub"

# LLM配置
llm:
  provider: "deepseek"  # 或 "openai", "anthropic"
  model: "deepseek-v3"
  api_key: ""  # 从环境变量读取
  temperature: 0.7
  max_tokens: 4000

# 数据验证配置
validation:
  max_price_change_pct: 30  # 单日最大涨跌幅
  warning_price_change_pct: 15  # 警告涨跌幅
  max_variance_pct: 2.0  # 多源数据最大差异
  warning_variance_pct: 0.5  # 警告差异
  z_score_high: 3.0  # 高度异常阈值
  z_score_medium: 2.0  # 中度异常阈值

# 组合配置
portfolio:
  initial_cash: 40000.0  # HKD
  max_position_pct: 25.0  # 单一持仓最大比例
  max_positions: 10  # 最大持仓数量

# 决策配置
decision:
  min_confidence: 0.5  # 最低信心度
  require_confirmation_below: 0.6  # 需要确认的信心度阈值
  
  # 三大原则权重
  principles:
    max_return: 0.4
    fast_return: 0.3
    min_risk: 0.3

# 监控配置
monitoring:
  check_interval: 300  # 检查间隔（秒）
  stop_loss_warning_pct: 5  # 接近停损警告（距离停损的百分比）

# Telegram通知配置
telegram:
  enabled: false
  bot_token: ""
  chat_id: ""

# 数据库配置
database:
  memory_db: "data/reishi_memory.db"
  knowledge_db: "data/company_relationships.db"
  max_age_days: 90  # 知识图谱数据最大保留天数

# 报告配置
report:
  output_dir: "reports/daily"
  format: "markdown"  # markdown, html, pdf
  include_analysis_details: true
  verification_links: true

# MVP限制
mvp:
  max_scan_stocks: 50  # 最大扫描股票数
  enable_llm_verification: false  # 是否启用LLM图表验证
  enable_web_search: false  # 是否启用网络搜索
  cost_target_monthly: 10  # 月度成本目标（USD）
