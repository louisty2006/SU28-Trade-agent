# 股票掃描系統 v4 環境變數配置（美股專用）
# 複製此文件為 .env 並填入你的 API Keys

# ============================================================================
# 🎯 三數據源強制驗證系統
# 每支股票必須有 3 個有效數據源，系統會自動從以下數據源池中選擇
# ============================================================================

# ============================================================================
# 主力數據源（優先使用）
# ============================================================================

# 1. Yahoo Finance - 不需要 API Key（內建於 yfinance）
#    額度：無限制 ✅
#    可靠性：⭐⭐⭐⭐⭐

# 2. IEX Cloud（強烈推薦）
#    註冊：https://iexcloud.io/
#    免費額度：50,000 calls/月 (≈ 1,666/天) ✅✅✅
#    可靠性：⭐⭐⭐⭐⭐
IEX_CLOUD_API_KEY=your_iex_cloud_api_key_here


# ============================================================================
# 備用數據源（按優先順序）
# ============================================================================

# 3. Twelve Data
#    註冊：https://twelvedata.com/
#    免費額度：800 calls/天 ✅✅
#    可靠性：⭐⭐⭐⭐
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# 4. Tiingo
#    註冊：https://www.tiingo.com/
#    免費額度：500 calls/天 ✅✅
#    可靠性：⭐⭐⭐⭐
TIINGO_API_KEY=your_tiingo_api_key_here

# 5. Intrinio
#    註冊：https://intrinio.com/
#    免費額度：500 calls/天 ✅
#    可靠性：⭐⭐⭐⭐
INTRINIO_API_KEY=your_intrinio_api_key_here

# 6. Finnhub
#    註冊：https://finnhub.io/
#    免費額度：60 calls/分鐘 (≈ 1,440/天) ✅✅
#    可靠性：⭐⭐⭐⭐
FINNHUB_API_KEY=your_finnhub_api_key_here

# 7. Financial Modeling Prep (FMP)
#    註冊：https://site.financialmodeprep.com/developer/docs/
#    免費額度：250 calls/天 ✅
#    可靠性：⭐⭐⭐⭐
FMP_API_KEY=your_fmp_api_key_here

# 8. Polygon.io
#    註冊：https://polygon.io/
#    免費額度：5 calls/分鐘 (≈ 250/天) ✅
#    可靠性：⭐⭐⭐⭐
POLYGON_API_KEY=your_polygon_api_key_here

# 9. Quandl/NASDAQ Data Link
#    註冊：https://data.nasdaq.com/
#    免費額度：50 calls/天
#    可靠性：⭐⭐⭐
QUANDL_API_KEY=your_quandl_api_key_here

# 10. Alpha Vantage
#     註冊：https://www.alphavantage.co/support/#api-key
#     免費額度：25 calls/天（太少，最後備用）
#     可靠性：⭐⭐⭐
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# 11. Marketstack
#     註冊：https://marketstack.com/
#     免費額度：100 calls/月 (≈ 3/天)（太少，最後備用）
#     可靠性：⭐⭐
MARKETSTACK_API_KEY=your_marketstack_api_key_here


# ============================================================================
# 💡 推薦配置（最小可用）
# ============================================================================
# 只需要註冊前 3 個就夠用：
# 1. Yahoo Finance（不需要註冊）
# 2. IEX Cloud（1,666/天）
# 3. Twelve Data（800/天）
# 
# 總計：2,466/天（Yahoo 不計），足夠處理 Stage 2 的 1000 支股票
#
# 如果想要更穩定，再加：
# 4. Tiingo（500/天）
# 5. Finnhub（1,440/天）
# 
# 總計：4,406/天，極度充裕！
# ============================================================================


# ============================================================================
# Stage 3 LLM API Keys（目前使用）
# ============================================================================

# Scitely（免費無限制，50+ AI 模型）✅ 目前使用
#    註冊：https://chat.scitely.com
#    社群額度：無限制（fair usage）
#    可靠性：⭐⭐⭐⭐⭐
#    模型：DeepSeek, Qwen, Kimi, Llama, GLM 等
SCITELY_API_KEY=your_scitely_api_key_here

# Cohere (Command A)
#    註冊：https://dashboard.cohere.com/
#    免費額度：1,000 calls/月
COHERE_API_KEY=your_cohere_api_key_here

# Mistral AI
#    註冊：https://console.mistral.ai/
#    免費額度：需要信用卡（但有試用額度）
MISTRAL_API_KEY=your_mistral_api_key_here

# OpenRouter（宏觀分析師）✅ 目前使用
#    註冊：https://openrouter.ai/keys
#    免費額度：有免費額度，可選多種模型
#    模型：meta-llama/llama-3.1-8b-instruct 等，見 https://openrouter.ai/models
OPENROUTER_API_KEY=your_openrouter_api_key_here


# ============================================================================
# 其他備用 LLM（可選）
# ============================================================================

# Groq (免費 LLM，速度快)
# GROQ_API_KEY=your_groq_api_key_here

# HuggingFace (Router API) - 已改為 OpenRouter
# HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Claude API (Anthropic)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API (GPT-4)
# OPENAI_API_KEY=your_openai_api_key_here

# Google AI API (Gemini) - 已移除（地區限制）
# GEMINI_API_KEY=your_gemini_api_key_here

# Perplexity API
# PERPLEXITY_API_KEY=your_perplexity_api_key_here

# === 中國友好 LLM ===
# 阿里雲通義千問 (https://dashscope.console.aliyun.com/)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 矽基流動 SiliconFlow (https://siliconflow.cn/)
SILICONFLOW_API_KEY=your_siliconflow_api_key_here


# ============================================================================
# v5.0 新增：Telegram 通知配置
# ============================================================================

# Telegram Bot（用于每日报告和即时警报）
#    创建步骤：
#    1. 在 Telegram 搜索 @BotFather
#    2. 发送 /newbot 创建新 bot
#    3. 获取 bot token
#    4. 获取 chat_id：发送消息给你的 bot，然后访问
#       https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
